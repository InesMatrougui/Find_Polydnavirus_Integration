reduction_contig_small_size <- filter(dt_hits_cons, V5<200000) %>%
mutate(end_contig=V5+1, start_contig=1) #%>% select(V3,start_contig, end_contig) %>%
#  distinct(.keep_all = TRUE)
reduction_contig_big_size <-  filter(dt_hits_cons,V5>=200000) %>%
mutate(start_contig=if_else(FinalStart<100000, 1, FinalStart-100000),
end_contig=if_else(FinalEnd+100000>V5, V5, FinalEnd+100000)) #%>%
#  select(V3,start_contig, end_contig) %>%
#  distinct(.keep_all = TRUE)
reduction_contig_size <- rbind(reduction_contig_small_size, reduction_contig_big_size) %>%
select(V3,start_contig, end_contig) %>%
distinct(.keep_all = TRUE)
setorder(reduction_contig_size, V3, start_contig)
contig_flank <-filter(dt_hits_cons, HIM=='J1_J2_HIM') %>% mutate(p1_meta = if_else(HIMstart<V10 & HIMend>V10, V12, V13),
p1_meta_bis = if_else(HIMstart<V10 & HIMend>V10, V13, V12),
p2_meta = if_else(p1_meta<p1_meta_bis, p1_meta-200000, p1_meta+200000)) %>%
mutate(p2_meta=if_else(p2_meta<0, 1, p2_meta),
p2_meta=if_else(p2_meta>V5, V5, p2_meta)) %>%
mutate(start_contig=if_else(p1_meta<p2_meta, p1_meta, p2_meta),
end_contig=if_else(p1_meta<p2_meta, p2_meta, p1_meta)) %>%
filter(start_contig!=end_contig) %>%
select(V3,start_contig, end_contig, order, family, genspe) %>%
distinct(.keep_all = TRUE)
contig_without_HIM_1 <- filter(dt_hits_cons, HIM=='inside_HIM') %>%
mutate(end_contig=if_else(V12<V13, V12, V13),
start_contig=if_else(end_contig > 200000, end_contig-200000, 1)) %>%
filter(start_contig!=end_contig) %>%
select(V3,start_contig, end_contig, order, family, genspe) %>%
distinct(.keep_all = TRUE)
contig_without_HIM_2 <- filter(dt_hits_cons, HIM=='inside_HIM') %>%
mutate(start_contig=if_else(V12>V13, V12, V13),
end_contig=if_else(V5 > start_contig+200000, start_contig+200000, V5))%>%
filter(start_contig!=end_contig) %>%
select(V3,start_contig, end_contig, order, family, genspe) %>%
distinct(.keep_all = TRUE)
contig_flank_1 <- rbind(contig_flank, contig_without_HIM_1, contig_without_HIM_2) %>%
select(V3,start_contig, end_contig)
setorder(contig_flank_1, V3, start_contig)
