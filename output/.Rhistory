# Script by Ines Matrougui
# 04/09/2025
setwd("G:/PDV_arthopodes/Input_R/In_used/")
# Packages used
library(data.table)
library(dplyr)
library(tidyverse)
library(ggplot2)
#
#import tabular blastn output [outputblastn]
#this blastn outputs were obtained using script_blastn_genome_arthro_vs_PDV.sh
#PDV_segments used ...
dt=fread(paste0("C:/Users/Inès Matrougui/Documents/Thèse_ines/PDV_arthopodes/outputblastn_arthro_vs_PDV_ALL_11.txt"))
dt=dt[dt$V14<0.0001 & dt$V7>164]
dt <- mutate(dt, num=c(1:nrow(dt)))
# Integration mediated by HIM ---------------------------------------------
#import coordinates of PDV HIM boundaries [ ... ]
HIM=fread("HIMcoord.txt")
HIM <- mutate(HIM, HIMStart=if_else(HIMstart<HIMend,HIMstart,HIMend),
HIMEnd=if_else(HIMstart<HIMend,HIMend,HIMstart))
#import names of PDV [ ... ]
seg=fread("Segments.txt", header=FALSE)
#filter out all blastn hits involving segments devoid of HIM
dt_seg_HIM=dt[dt$V1 %in% HIM$SegmentName]
#number of blastn hits involving PDV devoid of HIM
dt_seg_no_HIM=dt[!(dt$V1 %in% HIM$SegmentName)]
setorder(dt_seg_no_HIM, -V7)
#filter out all blastn hits involving in new HIM
dt_seg_newHIM=anti_join(dt, seg, by="V1")
#we determine the direction in which the target is aligned
dt_seg_HIM$strand=ifelse(dt_seg_HIM$V12 < dt_seg_HIM$V13, "+", "-")
#add column with HIM start coordinate
dt_seg_HIM$HIMstart=HIM$HIMStart[match(dt_seg_HIM$V1, HIM$SegmentName)]
#add column with HIM end coordinate
dt_seg_HIM$HIMend=HIM$HIMEnd[match(dt_seg_HIM$V1, HIM$SegmentName)]
#create data table containing all blastn hits covering both HIM boundaries (we expect very few if integration is mediated by HIM)
dtHIMstart_End=dt_seg_HIM[dt_seg_HIM$V10 > dt_seg_HIM$HIMend & dt_seg_HIM$V11 < dt_seg_HIM$HIMstart | dt_seg_HIM$V11 > dt_seg_HIM$HIMend & dt_seg_HIM$V10 < dt_seg_HIM$HIMstart]
#create data table containing all blastn hits for which start or end coordinate fall between HIM start and HIM end coordinates (as expected if integration occurs through breaks within HIM)
dtHIM=dt_seg_HIM[dt_seg_HIM$V10 < dt_seg_HIM$HIMend & dt_seg_HIM$V10 > dt_seg_HIM$HIMstart | dt_seg_HIM$V11 < dt_seg_HIM$HIMend & dt_seg_HIM$V11 > dt_seg_HIM$HIMstart]
#determine which coordinate in HdIV falls in HIM
dtHIM$coordHIM=ifelse(dtHIM$V10<dtHIM$HIMend & dtHIM$V10>dtHIM$HIMstart, dtHIM$V10, dtHIM$V11)
#we determine to which junction corresponds each blastn hit based on coordinates in HdIV
dtHIM$junction=ifelse(dtHIM$V11 > dtHIM$coordHIM, "J2", "J1")
#we determine if host contig is aligned in sense or antisense orientation
dtHIM$rev=dtHIM$V12 > dtHIM$V13
dtHIM$stran=ifelse(dtHIM$rev==FALSE, "+", "-")
###########################################################################
# New_HIM_arthro à annoter ------------------------------------------------
#we determine the direction in which the target is aligned
dt_seg_newHIM$strand=ifelse(dt_seg_newHIM$V12 < dt_seg_newHIM$V13, "+", "-")
#import coordinates of PDV new HIM boundaries [ ... ]
new_HIM=fread("seg_new_HIM.txt")
#add column with HIM start coordinate
dt_seg_newHIM$HIMstart=new_HIM$startHIMcontig[match(dt_seg_newHIM$V1, new_HIM$V1)]
#add column with HIM end coordinate
dt_seg_newHIM$HIMend=new_HIM$endHIMcontig[match(dt_seg_newHIM$V1, new_HIM$V1)]
#create data table containing all blastn hits covering both HIM boundaries (we expect very few if integration is mediated by HIM)
dtHIM_newStart_End=filter(dt_seg_newHIM, (V10 > HIMend & V11 < HIMstart) | (V11 > HIMend & V10 < HIMstart))
#create data table containing all blastn hits for which start or end coordinate fall between HIM start and HIM end coordinates (as expected if integration occurs through breaks within HIM)
dtnewHIM=filter(dt_seg_newHIM, (V10 <= HIMend & V10 >= HIMstart) | (V11 <= HIMend & V11 >= HIMstart))
#determine which coordinate in HdIV falls in HIM
dtnewHIM$coordHIM=ifelse(dtnewHIM$V10<dtnewHIM$HIMend & dtnewHIM$V10>dtnewHIM$HIMstart, dtnewHIM$V10, dtnewHIM$V11)
#we determine if host contig is aligned in sense or antisense orientation
dtnewHIM$rev=dtnewHIM$V12 > dtnewHIM$V13
dtnewHIM$stran=ifelse(dtnewHIM$rev==FALSE, "+", "-")
#we determine to which junction corresponds each blastn hit based on coordinates in HdIV
dtnewHIM <- separate(dtnewHIM, V1, into=c('PDV', 'junction', 'arthro'), sep= '-')
dtnewHIM <- tidyr::unite(dtnewHIM, col="V1", c('PDV','arthro'), sep= '-')
#merged the HIM files and new HIM files
dtnewHIM <-  select(dtnewHIM, V1, V2, V3, V4, V5, V6, V7, V8, V9, V10, V11, V12, V13, V14, V15, V16, num, strand, HIMstart, HIMend, coordHIM, junction, rev,  stran)
dtHIM = rbind(dtHIM, dtnewHIM) %>%
mutate(HIM='J1_J2_HIM')
###########################################################################
# relax the stringency at the HIM ------------------------------------------------
dt_seg_HIM_expand <- rbind(dt_seg_HIM, dt_seg_newHIM) %>%
filter(!(num %in% dtHIM$num)) %>%
mutate(HIMstart_100=HIMstart-100, HIMend_100=HIMend+100)
dtHIM_expand=filter(dt_seg_HIM_expand, (HIMstart_100 < V10 & HIMend_100 > V10) | (HIMstart_100 < V11 & HIMend_100 > V11) |
(HIMstart_100 > V10 & HIMend_100 < V11) | (HIMstart_100 > V11 & HIMend_100 < V10)) %>%
mutate(coordHIM='NA',junction='NA') %>%
select(-HIMstart_100, -HIMend_100)
dtHIM_expand$rev=dtHIM_expand$V12 > dtHIM_expand$V13
dtHIM_expand$stran=ifelse(dtHIM_expand$rev==FALSE, "+", "-")
dtHIM_expand <- mutate(dtHIM_expand,HIM=if_else((V10<HIMstart & V11<HIMend) | (V10>HIMstart & V11>HIMend), "outside_HIM",
if_else((V10 <= HIMstart & V11 >= HIMend) | (V11 <= HIMstart & V10 >= HIMend), "inside_HIM", "NA")))
dtHIM <- rbind(dtHIM, dtHIM_expand)
###########################################################################
# Taxonomy of genomes used ------------------------------------------------
#new column to get species name
#new dt to get species name
dtHIM$V4=gsub(pattern = "TPA_asm: ", replacement = "", x = dtHIM$V4)
species=as.data.table(tstrsplit(dtHIM$V4, " ", fixed=TRUE))
species_NA=filter(species, is.na(V2)) %>%
distinct(V1)
#add column with species name
dtHIM$gen=species$V2
dtHIM$spe=species$V3
dtHIM$genspe=paste(dtHIM$gen, dtHIM$spe, sep = "_")
setorder(dtHIM, V4, -V15)
dtHIM_unique=dtHIM[!duplicated(dtHIM$V4)]
# Species number with integration
nrow(distinct(dtHIM,genspe))
nrow(distinct(dtHIM,V16))
# Determine the taxonomy of genomes used
# extract the taxID from genomes used -> ncbi_dataset.tsv : https://www.ncbi.nlm.nih.gov/datasets/genome/
# import ncbi_dataset.tsv
genome <- read.table("id_genome_protostomia.txt", sep="\t", header = FALSE, na.strings="")
genome <- setNames(genome, c('accession_ID', 'assembly_name', 'organism_name', 'taxoID', 'status', 'genome_length', 'assembly_level', 'date', 'WGS', 'nb_scaffold')) #%>%
genome <- as.data.table(tstrsplit(genome$accession_ID, ".", fixed=TRUE)) %>%
cbind(select(genome, -accession_ID)) %>%
#rename("accession_ID"="V1") %>%
select(-V2)
names(genome)[1] <- "accession_ID"
# extract the TaxID
taxID <- select(genome, taxoID) %>%
distinct_all()
#write.table(taxID, "taxID.txt",row.names = F, col.names = F, quote = F, sep = ",")
# Determine tha taxonomy with efetch from taxID
# efetch -db taxonomy -id taxID -format xml |   xtract -pattern Taxon -last TaxId -block "*/Taxon" -unless Rank -equals "no rank" -tab "," -sep ":" -element Rank,ScientificName >> taxonomy_genome.txt
# import taxonomy
taxo <- read.delim("taxonomy_genome.txt", sep=",", header=FALSE, fill= TRUE, na.strings="")
# edit the table to have ranks on one column
taxo_1 <- separate(taxo, V1, into=c('taxoID', 'V1'), sep= '\t')
taxo_2 <- pivot_longer(taxo_1, col=-1) %>%
separate(value, into=c('Rank', 'taxonomy'), sep= ':') %>%
drop_na()
# edit the table to have one column per ranks
taxo_3 <- pivot_wider(taxo_2, id_cols=taxoID, names_from = Rank, values_from = taxonomy, values_fn = list) %>%
select(taxoID, superkingdom, kingdom, phylum, class, order, family, genus)%>%
mutate(across(everything(), as.character))
taxo_3$taxoID <- as.integer(taxo_3$taxoID)
# fusion the genome table and the taxonomy table to have the species names of each genome
genome_taxo_all <- left_join(genome, taxo_3, by='taxoID')
genome_taxo_all <-  mutate(genome_taxo_all, genspe=str_replace(genome_taxo_all$organism_name, " ", "_")) %>%
separate(genspe, into=c('genspe', 'plus'), sep= ' ') %>%
select(accession_ID, superkingdom, kingdom, phylum, class, order, family, genus, genspe)
genome_taxo <-  distinct(genome_taxo_all, accession_ID, .keep_all = TRUE)
genome_taxo <- genome_taxo %>% replace(genome_taxo == "NULL", NA)
genome_taxo <- data.frame(sapply(genome_taxo, unlist))
#write.table(genome_taxo, "genome_taxo.txt",row.names = F, col.names = T, quote = F, sep = "\t")
# add taxonomy to hit blastn
dtHIM <-left_join(dtHIM, genome_taxo, by= c('V16'='accession_ID')) %>%
select(-genspe.x)
names(dtHIM)[35] <- "genspe"
# check if all hit blastn have a taxonomy
dt_no_taxo <- filter(dtHIM,is.na(superkingdom))
###########################################################################
# identify coordonates of real integrations by distinguishing between confounding hits ------------------------------------------------------
# create a list of contig accession numbers to download the sequence for each contig
accesion <- select(dtHIM, V3) %>% distinct_all()
#write.table(accesion, "accession_number.txt", row.names = F, col.names = F, quote = F, sep = "\t")
# Download contigs : esearch -db nucleotide -query accession_number | efetch -format fasta > contig.fasta
dt_HIM2 <- mutate(dtHIM, num=c(1:nrow(dtHIM))) # add a number to each blastn hit
setorder(dt_HIM2, V3, V15) # sort hits by bitscore
dt_coor_int <-select(dt_HIM2, V3, V12, V13, num) %>%
mutate(start=if_else(V12<V13, V12, V13),  # determine start and end coordinates of PDV in host contig
end=if_else(V12<V13, V13, V12) ) %>%
cbind(dt_HIM2[, c("V15", "stran")]) %>%
select(V3, start, end,  num, V15, stran)
setorder(dt_coor_int, V3, start) # sort hits by bitscore
#create BED with name of lepidopteran contig, start and end coordinate of HdIV fragment to merge them
#this is to remove redundancy caused by the fact that some segments are similar to each other and thus some lepidopteran PDV fragments align to both of them (e.g. Hd12 and Hd16 or BV10 and BV17)
#write.table(dt_coor_int, "toMerge_dtHIM_all_expand.txt", row.names = F, col.names = F, quote = F, sep = "\t")
#Coordinates are merged using the following commands: dos2unix toMerge.txt and bedtools merge -s -c 4 -o distinct -i toMerge_dtHIM_all.txt  > toMerge_merged_all.txt
merged=fread("toMerge_merged_expand_all.txt")
ref=as.data.table(tstrsplit(merged$V4, ",", fixed = TRUE))
names(ref)[1] <- "ref"
merged <- cbind(merged,ref[,1])#add merged start coordinate to initial dt (dtHIM)
dt_HIM2$FinalStart=merged$V2[match(dt_HIM2$num, merged$ref)]
dt_HIM2$FinalEnd=merged$V3[match(dt_HIM2$num, merged$ref)]
#remove all blastn hits that do not have merged blastn coordinates (those that have been merged with other blastn hits)
dt_HIM2=dt_HIM2[!is.na(dt_HIM2$FinalEnd)]
dtHIM=dt_HIM2
#write.table(dtHIM, "dtHIM_all_100.txt", row.names = F, col.names = T, quote = F, sep = "\t")
###########################################################################
# add J1 or J2 id the Finalstart or finalend fall between HIM start and HIM end coordinates
dtHIM <- left_join(dtHIM, select(dt_coor_int, start, end, num), by='num') %>%
mutate(Finalstart_V10=V10-(start-FinalStart),
Finalend_V11=V11+(FinalEnd-end))
dtHIM_100 <- mutate(dtHIM, start=if_else(V12<V13, V12, V13),
end=if_else(V12<V13, V13, V12)) %>%
mutate(Finalstart_V10=V10-(start-FinalStart),
Finalend_V11=V11+(FinalEnd-end)) %>%
mutate(Finalstart_V10= if_else(Finalstart_V10<=0, 1, Finalstart_V10)) %>%
mutate(num=c(1:nrow(dtHIM))) %>%
mutate(HIM=if_else((Finalstart_V10 < HIMend & Finalstart_V10 > HIMstart) | (Finalend_V11 < HIMend & Finalend_V11 > HIMstart), "J1_J2_HIM", HIM))
