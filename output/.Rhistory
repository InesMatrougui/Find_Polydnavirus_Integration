dt <- fread("dt_integration_final.txt") %>% filter(HIM=="J1_J2_HIM") %>%
select(query_id, query_length, subject_id, subject_length, alignment_length, FinalStart, FinalEnd,
Finalstart_V10, Finalend_V11, stran, HIMstart, HIMend, junction, order, genspe, num)
coor_TE_in_hit_seg <- fread("G:/PDV_arthopodes/Input_R/In_used/Annotation_gene_TE_LCR/coor_TE_in_hit_seg_06_12.txt") %>%
mutate(Rep='ET')
coor_TE_in_hit_seg <- setnames(coor_TE_in_hit_seg, c("query_id", "TE_start", "TE_end", "num","stran", "Rep")) %>%
mutate(Rep=if_else(Rep=="ET", "TE", Rep)) %>%
distinct_all()
coor_TE_in_hit_seg$num <- as.integer(coor_TE_in_hit_seg$num)
dt_TE <- left_join(dt, coor_TE_in_hit_seg, by=c("num", "query_id", "stran")) %>% # add the hits table dtHIM_100
mutate(TE_len=TE_end-TE_start) %>% # calculate the length of the TE on hits
mutate(len= Finalend_V11-Finalstart_V10) %>%  # calculate the length of the hits
distinct(num, .keep_all = TRUE) %>% # delete if duplicate rows
mutate(prop_TE= TE_len/len) %>% # calculate the proportion of LCR relative to the hit
mutate(prop_TE=if_else(is.na(prop_TE), 0, prop_TE)) # add 0 if there is no LCR
View(dt_TE)
# Histogram of the proportion of LCR relative to the hit
ggplot(filter(dt_TE)) + geom_histogram(aes(x=prop_TE),color="black", bins = 50,  position = "identity") +
theme_bw() +
labs(x = "Alignment ratio between hits and LCR", y = "Number of hits")
ggplot(filter(dt_TE)) + geom_histogram(aes(x=TE_len),color="black", bins = 50,  position = "identity") +
theme_bw() +
labs(x = "Alignment ratio between hits and LCR", y = "Number of hits")
ggplot(filter(dt_TE)) + geom_point(aes(x=prop_TE, y =prop_TE)) +
theme_bw()
ggplot(filter(dt_TE)) + geom_point(aes(x=TE_len, y =prop_TE)) +
theme_bw()
dt_TE <- dt_TE %>% filter(TE_len>300 & prop_TE<50)
View(dt_TE)
ggplot(filter(dt_TE)) + geom_histogram(aes(x=len),color="black", bins = 50,  position = "identity") +
theme_bw()
